{
    "name": "netvora/noc-isp",
    "description": "NETVORA NOC & ISP Management System - PHP 8.3 Native MVC, Supabase PostgreSQL, JWT + RBAC, Multi-Tenant",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "ext-snmp": "*",
        "ext-mbstring": "*",
        "ext-simplexml": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Core/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php",
        "cron": "php cron/scheduler.php"
    }
}
